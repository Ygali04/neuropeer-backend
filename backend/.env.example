# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://neuropeer:neuropeer@localhost:5432/neuropeer

# Redis (also used as Celery broker)
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO storage
S3_BUCKET=neuropeer-media
S3_ENDPOINT_URL=http://localhost:9000  # leave empty for real AWS S3
AWS_ACCESS_KEY_ID=neuropeer
AWS_SECRET_ACCESS_KEY=neuropeer123
AWS_REGION=us-east-1

# JWT auth
SECRET_KEY=change-me-in-production

# HuggingFace (needed to download facebook/tribev2)
HF_TOKEN=hf_your_token_here

# Model config
TRIBE_MODEL_ID=facebook/tribev2
DEVICE=cpu               # cuda for GPU inference

# ElevenLabs (Scribe v2 speech-to-text transcription)
# Get your API key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Temp storage for downloaded videos
TEMP_DIR=/tmp/neuropeer

# ── yt-dlp download configuration ──────────────────────────────────────────────
#
# YTDLP_COOKIES_FILE — path to a Netscape-format cookies.txt file.
# Required for: Instagram, Facebook, age-gated YouTube, any auth-walled content.
#
# How to generate cookies.txt:
#   1. Use Firefox (Chrome cookie extraction is broken since July 2024)
#   2. Install the "cookies.txt" Firefox add-on
#   3. Log in to Instagram (or the target platform) in Firefox
#   4. Click the extension icon → Export cookies for current site → save as cookies.txt
#   5. Mount the file into the worker container (see docker-compose.yml volume comment)
#   6. Set this env var to the mounted path
#
# NOTE: Cookies expire after 30-90 days or when you log out. Re-export if downloads fail.
YTDLP_COOKIES_FILE=/run/secrets/cookies.txt

# Optional: custom browser User-Agent (leave empty to use yt-dlp default)
YTDLP_USER_AGENT=

# Retry config for rate-limited platforms
YTDLP_MAX_RETRIES=3
YTDLP_RETRY_BACKOFF=15.0

# ── Residential proxy (required for Instagram/Facebook from cloud IPs) ─────────
#
# Meta blocks datacenter and cloud provider IPs from downloading Instagram/Facebook content.
# A rotating residential proxy routes requests through real residential IP addresses.
#
# Recommended: Oxylabs Residential Proxies ($8-15/GB, rotating session IDs)
#   https://oxylabs.io/products/residential-proxy-pool
#
# Setup:
#   1. Create an Oxylabs account and get your username/password
#   2. Set PROXY_URL to the Oxylabs endpoint
#   3. Set PROXY_USERNAME to your Oxylabs username (session IDs are appended automatically)
#   4. Set PROXY_PASSWORD to your Oxylabs password
#
# The worker auto-generates a fresh session ID per download request to distribute
# traffic across many IPs and avoid per-session rate limits.
#
PROXY_URL=http://proxy.oxylabs.io:60000
PROXY_USERNAME=your_oxylabs_username
PROXY_PASSWORD=your_oxylabs_password

# ── Remote GPU inference (DataCrunch.io A100 spot instances) ──────────────────
#
# Set INFERENCE_BACKEND=datacrunch to spin up an A100 per job instead of local GPU.
# Set INFERENCE_BACKEND=local to run TRIBE v2 on the Celery worker itself.
#
# DataCrunch spot instance flow:
#   Job submitted → worker ingests video (CPU) → stages events.parquet to S3
#   → DataCrunch API spins up A100 spot → instance runs TRIBE v2 × 4 passes
#   → predictions.npz + sentinel uploaded to S3 → worker polls S3
#   → worker downloads predictions → runs metrics (CPU) → broadcasts results
#   → worker deletes instance
#
# A100 80GB spot pricing: $0.45/hour
# Install SDK: pip install datacrunch
# Docs: https://datacrunch-python.readthedocs.io
#
INFERENCE_BACKEND=local   # local | datacrunch

# DataCrunch OAuth2 credentials (only needed for INFERENCE_BACKEND=datacrunch)
# Generate at the DataCrunch dashboard → API credentials
DATACRUNCH_CLIENT_ID=your_client_id_here
DATACRUNCH_CLIENT_SECRET=your_client_secret_here
# OS image (CUDA pre-installed, deps installed via startup script)
DATACRUNCH_IMAGE=ubuntu-24.04-cuda-12.8-open-docker
# Instance type: 1A100.80G ($0.45/h spot), 1A100.40G ($0.25/h spot)
DATACRUNCH_INSTANCE_TYPE=1A100.80G
# Comma-separated SSH key IDs from DataCrunch dashboard
DATACRUNCH_SSH_KEY_IDS=
# Max seconds to wait for instance to boot + complete inference
DATACRUNCH_BOOT_TIMEOUT=600
